    "Complete a level to unlock its words as collectible study cards." : {
      "localizations" : {
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "Kelimelerini koleksiyonluk çalışma kartları olarak açmak için bir bölümü tamamla." } },
