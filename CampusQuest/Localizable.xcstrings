    "Guest mode keeps your progress on this device only. No account, no cloud sync, no leaderboard — and no personal data or statistics are collected or stored." : {
      "localizations" : {
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "Misafir modu ilerlemeni yalnızca bu cihazda tutar. Hesap yok, bulut eşitleme yok, lider tablosu yok — ve hiçbir kişisel veri veya istatistik toplanmaz ya da saklanmaz." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Im Gastmodus bleibt dein Fortschritt nur auf diesem Gerät. Kein Konto, keine Cloud-Synchronisierung, keine Bestenliste – und es werden keine persönlichen Daten oder Statistiken erfasst oder gespeichert." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Le mode invité conserve votre progression uniquement sur cet appareil. Pas de compte, pas de synchronisation cloud, pas de classement — et aucune donnée personnelle ni statistique n'est collectée ou stockée." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "El modo invitado guarda tu progreso solo en este dispositivo. Sin cuenta, sin sincronización en la nube, sin clasificación, y no se recopilan ni almacenan datos personales ni estadísticas." } }
      }
    },
    "Guest mode · this device only" : {
      "localizations" : {
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "Misafir modu · yalnızca bu cihaz" } },
