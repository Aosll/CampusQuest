    "No badges yet — complete levels and quizzes to earn your first one." : {
      "localizations" : {
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "Henüz rozet yok — ilk rozetini kazanmak için bölümleri ve testleri tamamla." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Noch keine Abzeichen – schließe Level und Quizze ab, um dein erstes zu verdienen." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Pas encore de badge — terminez des niveaux et des quiz pour obtenir le premier." } },
